             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TDL.AdminView">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU -->
        <local:AdminOpciones x:Name="MenuAdmin"/>

        <!-- CONTENIDO ADMIN -->
        <ContentControl x:Name="AdminContent" Grid.Column="1"/>

    </Grid>

</UserControl>