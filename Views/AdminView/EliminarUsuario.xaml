<UserControl x:Class="TDL.EliminarUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Background="#F3F4F6">

        <Border Width="420"
                Padding="30"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Eliminar Usuario"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Usuario"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="txtusuario"
                         Height="38"
                         FontSize="14"
                         Padding="10,5"
                         BorderBrush="#D1D5DB"
                         Background="#F9FAFB"
                         Margin="0,0,0,25"/>

                <Button Click="btnEliminar"
                        Content="ELIMINAR"
                        Height="42"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,12"/>

               
            </StackPanel>

        </Border>

    </Grid>
</UserControl>