<UserControl x:Class="TDL.BEAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   

        <Grid Background="#F5F7FA" Margin="10" >

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de Tareas"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="10"
                   Foreground="#2C3E50"/>

            <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="10"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <StackPanel>
                        <TextBlock Text="Buscar tarea"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                        <TextBox x:Name="txtbuscar"
                             Width="250"
                             Height="30"
                             Padding="5"
                             TextChanged="txtbuscar_TextChanged"/>
                    </StackPanel>

                    <Button x:Name="btnbuscar"
                        Content="Buscar"
                        Width="100"
                        Height="35"
                        Margin="15,20,0,0"
                        Background="#1E2D6B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnbuscar_Click"/>
                    <Button x:Name="btnSeleccionarTodo"
                        Content="Seleccionar Todo"
                        Width="100"
                        Height="35"
                        Margin="15,20,0,0"
                        Background="#1E2D6B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnSeleccionarTodo_Click"/>
                    <Button x:Name="btnimprimir"
                        Content="Imprimir"
                        Width="100"
                        Height="35"
                        Margin="15,20,0,0"
                        Background="#1E2D6B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnimprimir_Click"/>
               
               

                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Margin="10"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

                <DataGrid x:Name="dgbuscar"
                      AutoGenerateColumns="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"

                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#E5E7EB"
                      VerticalGridLinesBrush="#E5E7EB"

                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#F9FAFB"
                      AlternationCount="2"
                      BorderThickness="0">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF6FF"/>
                                </Trigger>


                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>


                        <DataGridTemplateColumn Header="Título" Width="*" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Titulo}"
                                           TextWrapping="Wrap"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Header="Descripción" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Descripcion}"
                                           TextWrapping="Wrap"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Header="Técnico" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tecnico}"
                                           TextWrapping="Wrap"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ESTADO -->
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Estado}"
                                           TextWrapping="Wrap"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Header="Prioridad" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Prioridad}"
                                           TextWrapping="Wrap"
                                           Margin="5"
                                           FontWeight="SemiBold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Alta">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Media">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Baja">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Header="Justificación" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Justificacion}"
                                           TextWrapping="Wrap"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- FECHA APERTURA -->
                        <DataGridTemplateColumn Header="Fecha Apertura" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Fecha_apertura, StringFormat={}{0:dd/MM/yyyy HH:mm} }"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- FECHA CIERRE -->
                        <DataGridTemplateColumn Header="Fecha Cierre" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Fecha_limite, StringFormat=dd/MM/yyyy}"
                                           Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </Border>

        </Grid>
  
</UserControl>
