<UserControl x:Class="TDL.AdminView.AdminOpciones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="250">

    <UserControl.Resources>

        <!-- ESTILO GENERAL BOTONES -->
        <Style x:Key="MenuButtonStyle"
               TargetType="Button">

            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Margin" Value="10,6"/>
            <Setter Property="Background" Value="#3248A8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>

    <Grid Background="White">

        <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <!-- LOGO -->
            <Image Source="/Images/bellasartes.ico"
               Width="100"
               Height="100"
               Margin="0,0,0,20"/>

            <!-- BOTONES -->
            <Button Content="Asignar Tarea"
                Style="{StaticResource MenuButtonStyle}"
                Click="AsignarTarea_Click"/>

            <Button Content="Buscar Tarea"
                Style="{StaticResource MenuButtonStyle}"
                Click="Buscar_Click"/>

            <Button Content="Editar Tarea"
                Style="{StaticResource MenuButtonStyle}"
                Click="EditarTarea_Click"/>
            
            <Button Content="Ver Historial"
                 Style="{StaticResource MenuButtonStyle}"
                 Click="Historial_Click"/>

            <Button Content="Agregar Usuario"
                Style="{StaticResource MenuButtonStyle}"
                Click="AgregarUsuario_Click"/>

            <Button Content="Eliminar Usuario"
                Style="{StaticResource MenuButtonStyle}"
                Click="EliminarUsuario_Click"/>

            <Button Content="Cambiar Contraseña"
                Style="{StaticResource MenuButtonStyle}"
                Click="CambiarPassword_Click"/>

            <Button Content="Cerrar Sesión"
                Style="{StaticResource MenuButtonStyle}"
                Click="CerrarSesion_Click"/>

        </StackPanel>

    </Grid>

</UserControl>