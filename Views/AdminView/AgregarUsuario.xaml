<UserControl x:Class="TDL.AgregarUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d"
             d:DesignHeight="550"
             d:DesignWidth="900">

    <Grid Background="#F5F7FA">

        <!-- CONTENEDOR -->
        <Border Width="650"
                Padding="30"
                Background="White"
                CornerRadius="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- TITULO -->
                <TextBlock Text="Agregar Usuario"
                           Grid.Row="0"
                           Grid.ColumnSpan="2"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- ROLES -->
                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,30">

                    <RadioButton Content="Técnico"
                                 FontSize="15"
                                 Margin="15,0"
                                 x:Name="rbtecnico"/>

                    <RadioButton Content="Secretaria"
                                 FontSize="15"
                                 Margin="15,0"
                                 x:Name="rbsecretaria"/>

                    <RadioButton Content="Administrador"
                                 FontSize="15"
                                 Margin="15,0"
                                 x:Name="rbadmin"/>

                </StackPanel>

                <!-- NOMBRE -->
                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Margin="10">

                    <TextBlock Text="Nombre"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <TextBox Height="38"
                             Padding="8"
                             FontSize="14"
                             x:Name="txtnombre"/>

                </StackPanel>

                <!-- PASSWORD -->
                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Margin="10">

                    <TextBlock Text="Contraseña"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <TextBox Height="38"
                                 Padding="8"
                                 FontSize="14"
                                 x:Name="txtpassword"/>

                </StackPanel>

                <!-- APELLIDO -->
                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="10">

                    <TextBlock Text="Apellido"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <TextBox Height="38"
                             Padding="8"
                             FontSize="14"
                             x:Name="txtapellido"/>

                </StackPanel>

                <!-- BOTON -->
                <Button Content="Agregar Usuario"
                        Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Height="45"
                        Margin="10,25,10,0"
                        Background="#3248A8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btnAgregar_Click">

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>

                    </Button.Template>

                </Button>

            </Grid>

        </Border>

    </Grid>

</UserControl>