<UserControl x:Class="TDL.AdminAggView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0"
           Margin="20"
           VerticalScrollBarVisibility="Auto"
           HorizontalScrollBarVisibility="Disabled">

            <Border Padding="25"
         Background="White"
         CornerRadius="12"
         BorderBrush="#E5E7EB"
         BorderThickness="1"
         HorizontalAlignment="Stretch">

                <StackPanel>

                    <!-- TÍTULO -->
                    <TextBlock Text="Gestión de Tareas"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#111827"
                    Margin="0,0,0,20"
                    TextAlignment="Center"/>

                    <!-- TÍTULO -->
                    <TextBlock Text="Título de Tarea" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtTitulo"
                  Height="35"
                  Margin="0,5,0,15"
                  Padding="5"
                  BorderBrush="#D1D5DB"/>

                    <!-- DESCRIPCIÓN -->
                    <TextBlock Text="Descripción" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDescripcion"
                  Height="70"
                  Margin="0,5,0,15"
                  TextWrapping="Wrap"
                  AcceptsReturn="True"
                  Padding="5"
                  BorderBrush="#D1D5DB"/>

                    <!-- FECHAS -->
                    <TextBlock Text="Fecha de Apertura" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpFechaa" Margin="0,5,0,15" />

                    <TextBlock Text="Fecha de Cierre" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpFecha" Margin="0,5,0,15"/>

                    <!-- USUARIO -->
                    <TextBlock Text="Asignar a" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbUsuarios"
                   Height="35"
                   Margin="0,5,0,15"/>

                    <!-- PRIORIDAD -->
                    <TextBlock Text="Prioridad"
                    FontWeight="SemiBold"
                    Margin="0,10,0,5"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                        <RadioButton x:Name="rbalta"
                          Content="Alta"
                          Margin="5"
                          Padding="10,5"
                          Background="RED"/>

                        <RadioButton x:Name="rbmedia"
                          Content="Media"
                          Margin="5"
                          Padding="10,5"
                          Background="Orange"/>

                        <RadioButton x:Name="rbbaja"
                          Content="Baja"
                          Margin="5"
                          Padding="10,5"
                          Background="Green"/>
                    </StackPanel>

                   
                    <Button Content="Asignar Tarea"
                 Height="40"
                 Margin="0,10,0,5"
                 Background="#1E2D6B"
                 Foreground="White"
                 FontWeight="SemiBold"
                 BorderThickness="0"
                 Cursor="Hand"
                 Click="AsignarTarea_Click"/>


                    

                 

                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Column="1"
     Margin="20"
     Padding="15"
     Background="#F9FAFB"
     CornerRadius="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

               
                <TextBlock Text="Listado de Tareas"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="#111827"
                Margin="5,0,0,10"/>

              
                <DataGrid x:Name="dgTareas"
               Grid.Row="1"
               AutoGenerateColumns="False"

               SelectionMode="Extended"
               SelectionUnit="FullRow"

               GridLinesVisibility="All"
               HorizontalGridLinesBrush="#E5E7EB"
               VerticalGridLinesBrush="#E5E7EB"

               HeadersVisibility="Column"
               RowBackground="White"
               AlternatingRowBackground="#F9FAFB"
               AlternationCount="2"

               Background="White"
               BorderThickness="0">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                   
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.CellStyle>

                 
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>

                            <Style.Triggers>
                                
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF6FF"/>
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

            
                    <DataGrid.Columns>

                 
                        <DataGridTemplateColumn Header="Título" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Titulo}"
                                    TextWrapping="Wrap"
                                    Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                     
                        <DataGridTemplateColumn Header="Descripción" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Descripcion}"
                                    TextWrapping="Wrap"
                                    Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                     
                        <DataGridTemplateColumn Header="Técnico" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tecnico}"
                                    TextWrapping="Wrap"
                                    Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                       
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Estado}"
                                    TextWrapping="Wrap"
                                    Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                      
                        <DataGridTemplateColumn Header="Prioridad" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Prioridad}"
                                    TextWrapping="Wrap"
                                    Margin="5"
                                    FontWeight="SemiBold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Alta">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Media">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Baja">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
