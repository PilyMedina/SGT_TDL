<UserControl x:Class="TDL.SecretariaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:TDL"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0"
              Margin="20"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

            <Border Padding="25"
            Background="White"
            CornerRadius="12"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            HorizontalAlignment="Stretch">

                <StackPanel>

                    <!-- TÍTULO -->
                    <TextBlock Text="Gestión de Tareas"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#111827"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

                    <!-- TÍTULO -->
                    <TextBlock Text="Título de Tarea" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtTitulo"
                     Height="35"
                     Margin="0,5,0,15"
                     Padding="5"
                     BorderBrush="#D1D5DB"/>

                    <!-- DESCRIPCIÓN -->
                    <TextBlock Text="Descripción" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDescripcion"
                     Height="70"
                     Margin="0,5,0,15"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="5"
                     BorderBrush="#D1D5DB"/>

                    <!-- FECHAS -->
                    <TextBlock Text="Fecha de Apertura" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpFechaa" Margin="0,5,0,15" DisplayDateStart="{x:Static sys:DateTime.Today}"/>

                    <TextBlock Text="Fecha de Cierre" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpFecha" Margin="0,5,0,15" DisplayDateStart="{x:Static sys:DateTime.Today}"/>

                    <!-- USUARIO -->
                    <TextBlock Text="Asignar a" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbUsuarios"
                      Height="35"
                      Margin="0,5,0,15"/>

                    <!-- PRIORIDAD -->
                    <TextBlock Text="Prioridad"
                       FontWeight="SemiBold"
                       Margin="0,10,0,5"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                        <RadioButton x:Name="rbalta"
                             Content="Alta"
                             Margin="5"
                             Padding="10,5"
                             Background="RED"/>

                        <RadioButton x:Name="rbmedia"
                             Content="Media"
                             Margin="5"
                             Padding="10,5"
                             Background="Orange"/>

                        <RadioButton x:Name="rbbaja"
                             Content="Baja"
                             Margin="5"
                             Padding="10,5"
                             Background="Green"/>
                    </StackPanel>

                    
                    <Button Content="Asignar Tarea"
                    Height="40"
                    Margin="0,10,0,5"
                    Background="#1E2D6B"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Button_Click_1"/>

                   
                    <Button Content="Buscar Tarea"
                    Height="35"
                    Margin="0,5"
                    Background="#1E2D6B"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BuscarTarea_Click"/>

                   
                    <Button Content="Cambiar Contraseña"
                    Height="35"
                    Margin="0,10,0,5"
                    Background="#1E2D6B"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Cambiarcontra_click"/>

                    <Button Content="Cerrar sesión"
                    Height="35"
                    Background="#EF4444"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CerrarSesion_click"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
        
        <Border Grid.Column="1"
        Margin="20"
        Padding="15"
        Background="#F9FAFB"
        CornerRadius="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <TextBlock Text="Listado de Tareas"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="5,0,0,10"/>

                <!-- TABLA -->
                <DataGrid x:Name="dgTareas"
                  Grid.Row="1"
                  AutoGenerateColumns="False"

                  SelectionMode="Extended"
                  SelectionUnit="FullRow"

                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#E5E7EB"
                  VerticalGridLinesBrush="#E5E7EB"

                  HeadersVisibility="Column"
                  RowBackground="White"
                  AlternatingRowBackground="#F9FAFB"
                  AlternationCount="2"

                  Background="White"
                  BorderThickness="0">

                    <!-- ENCABEZADO -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- CELDAS -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <!-- FILAS -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>

                            <Style.Triggers>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF6FF"/>
                                </Trigger>

                                <!-- Selección -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLUMNAS -->
                    <DataGrid.Columns>

                        <!-- TÍTULO -->
                        <DataGridTemplateColumn Header="Título" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Titulo}"
                                       TextWrapping="Wrap"
                                       Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- DESCRIPCIÓN -->
                        <DataGridTemplateColumn Header="Descripción" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Descripcion}"
                                       TextWrapping="Wrap"
                                       Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- TÉCNICO -->
                        <DataGridTemplateColumn Header="Técnico" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tecnico}"
                                       TextWrapping="Wrap"
                                       Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ESTADO -->
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Estado}"
                                       TextWrapping="Wrap"
                                       Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- PRIORIDAD -->
                        <DataGridTemplateColumn Header="Prioridad" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Prioridad}"
                                       TextWrapping="Wrap"
                                       Margin="5"
                                       FontWeight="SemiBold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Alta">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Media">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Prioridad}" Value="Baja">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
