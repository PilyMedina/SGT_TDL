<UserControl x:Class="TDL.Views.LoginView.TokenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TDL.Views.LoginView"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="#F3F5F9">

    <Grid>

        <Border Width="420"
                Padding="30"
                CornerRadius="18"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- TITULO -->
                <TextBlock Text="Verificación de Token"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- USERNAME -->
                <TextBlock Text="Nombre de usuario"
                         
                           FontSize="13"
                           Foreground="#555"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="txtUsuario"
                         Height="38"
                         FontSize="14"
                         Padding="8"
                         Margin="0,0,0,15"
                         BorderBrush="#D1D5DB"
                         Background="#FAFAFA"/>

                <!-- BOTON ENVIAR TOKEN -->
                <Button x:Name="btnEnviarToken"
                        Content="Enviar Token"
                        Click="EnviarToken_Click"
                        Height="40"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,25"/>

                <!-- TOKEN -->
                <TextBlock Text="Token"
                           FontSize="13"
                           Foreground="#555"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="txtToken"
                         Height="38"
                         FontSize="14"
                         Padding="8"
                         Margin="0,0,0,20"
                         BorderBrush="#D1D5DB"
                         Background="#FAFAFA"/>

                <!-- BOTON VALIDAR -->
                <Button x:Name="btnValidar"
                        Content="Validar Token"
                        Click="ValidarToken_Click"
                        Height="42"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#10B981"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button x:Name="btnSalir"
                          Content="Salir"
                          Click="Salir_Click"
                          Height="42"
                          FontSize="15"
                          FontWeight="SemiBold"
                          Background="#FF0017"
                          Foreground="White"
                          BorderThickness="0"
                          Cursor="Hand"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>