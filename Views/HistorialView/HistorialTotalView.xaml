<UserControl x:Class="TDL.Views.Historial.HistorialTotalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TDL.Views.Historial"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="10">

        <DataGrid x:Name="dgHistorial"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Tarea"
                    Binding="{Binding Tarea.Titulo}"/>

                <DataGridTextColumn
                    Header="Acción"
                    Binding="{Binding Accion}" />

                <DataGridTextColumn
                    Header="Descripción"
                    Binding="{Binding Descripcion}" />

                <DataGridTextColumn
                    Header="Fecha"
                    Binding="{Binding Fecha}" />

                <DataGridTextColumn
                    Header="Usuario"
                    Binding="{Binding Usuario.Nombre}" />

            </DataGrid.Columns>

        </DataGrid>
        </Grid>
</UserControl>
